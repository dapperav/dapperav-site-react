---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site, services, GA4_MEASUREMENT_ID, GOOGLE_SITE_VERIFICATION } from '../data/site';

interface Props {
  title: string;
  description: string;
  /** Additional JSON-LD blocks (FAQPage, Service, etc.) injected by pages */
  extraSchema?: object[];
}

const { title, description, extraSchema = [] } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.url}/#business`,
  name: site.name,
  url: site.url,
  telephone: '+19728241303',
  email: site.email,
  image: `${site.url}/og-image.png`,
  logo: `${site.url}/icon-512.png`,
  description: site.tagline,
  priceRange: '$$',
  areaServed: [
    { '@type': 'City', name: 'Richmond, TX' },
    { '@type': 'City', name: 'Rosenberg, TX' },
    { '@type': 'City', name: 'Fulshear, TX' },
    { '@type': 'City', name: 'Sugar Land, TX' },
    { '@type': 'City', name: 'Stafford, TX' },
    { '@type': 'City', name: 'Katy, TX' },
    { '@type': 'AdministrativeArea', name: 'Fort Bend County, TX' },
  ],
  geo: { '@type': 'GeoCoordinates', latitude: 29.5822, longitude: -95.7608 },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '18:00',
  },
  founder: { '@type': 'Person', name: 'Mark Immler' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'AV Installation Services',
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.title, description: s.blurb },
      ...(s.price
        ? { priceSpecification: { '@type': 'PriceSpecification', price: s.price, priceCurrency: 'USD' } }
        : {}),
    })),
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon-48.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#3b1005" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site.url}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Dapper AV Solutions — Professional. Precise. Personal." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${site.url}/og-image.png`} />
    {GOOGLE_SITE_VERIFICATION && <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {extraSchema.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
    {
      GA4_MEASUREMENT_ID && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`} />
          <script
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA4_MEASUREMENT_ID}');`}
          />
        </>
      )
    }
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-full focus:bg-gold focus:px-4 focus:py-2 focus:font-semibold focus:text-espresso"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <!-- keeps the last content clear of the mobile bottom dock -->
    <div class="h-24 md:hidden" aria-hidden="true"></div>

    <script>
      // Scroll reveals — fire once, then let the browser forget about them.
      const revealed = document.querySelectorAll('[data-reveal]');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-inview');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -5% 0px' }
        );
        revealed.forEach((el) => io.observe(el));
      } else {
        revealed.forEach((el) => el.classList.add('is-inview'));
      }
    </script>
  </body>
</html>
