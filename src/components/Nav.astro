---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { site } from '../data/site';

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Our Work' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!-- ── Top pill: desktop only. Collapses out of view on scroll down,
     returns on scroll up. Mobile navigation lives in the bottom dock. ── -->
<header id="site-nav" class="fixed inset-x-0 top-0 z-50 hidden px-3 pt-3 transition-transform duration-300 ease-out sm:px-6 md:block">
  <div
    class="glass mx-auto flex max-w-6xl items-center justify-between rounded-full px-5 py-3 transition-all duration-300 [#site-nav.is-condensed_&]:py-2 [#site-nav.is-condensed_&]:shadow-xl sm:px-7"
  >
    <a href="/" class="flex items-center gap-3" aria-label="Dapper AV Solutions — home">
      <Image src={logo} alt="" width="96" height="96" class="h-11 w-11 object-contain sm:h-12 sm:w-12" loading="eager" />
      <span class="font-display text-lg leading-tight font-semibold tracking-wide whitespace-nowrap">
        Dapper AV
        <span class="block text-[0.65rem] font-normal tracking-[0.28em] text-cocoa uppercase">Solutions</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 md:flex lg:gap-8" aria-label="Main">
      {
        links.map((l) => (
          <a
            href={l.href}
            aria-current={path === l.href ? 'page' : undefined}
            class="link-draw text-sm font-medium tracking-wide whitespace-nowrap text-espresso"
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={site.phoneHref}
        class="link-draw hidden text-sm font-medium tracking-wide whitespace-nowrap text-cocoa lg:inline-block"
      >
        {site.phone}
      </a>
      <a
        href="/quote"
        class="btn-sheen rounded-full bg-gold px-6 py-2.5 text-sm font-semibold tracking-wide whitespace-nowrap text-espresso shadow-sm transition-colors duration-300 hover:bg-gold-deep"
      >
        Request a Quote
      </a>
    </nav>

  </div>
</header>

<!-- ── Mobile bottom dock — the only nav on phones. Center logo = Home. ── -->
<nav
  class="glass fixed inset-x-3 bottom-3 z-50 rounded-3xl pb-[env(safe-area-inset-bottom)] md:hidden"
  aria-label="Mobile"
>
  <div class="grid grid-cols-5 items-end">
    <a
      href="/services"
      aria-current={path === '/services' ? 'page' : undefined}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa aria-[current=page]:text-gold-deep"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
        <rect x="2" y="4" width="20" height="13" rx="2.5" />
        <path d="M8 21h8m-4-4v4" />
      </svg>
      Services
    </a>
    <a
      href="/work"
      aria-current={path === '/work' ? 'page' : undefined}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa aria-[current=page]:text-gold-deep"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="3" />
        <circle cx="9" cy="9" r="2" />
        <path d="m21 15-3.5-3.5a2 2 0 0 0-2.83 0L6 20" />
      </svg>
      Our Work
    </a>
    <a
      href="/"
      aria-current={path === '/' ? 'page' : undefined}
      aria-label="Dapper AV Solutions — home"
      class="group relative flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa aria-[current=page]:text-gold-deep"
    >
      <span
        class="glass -mt-8 flex h-14 w-14 items-center justify-center rounded-full shadow-lg transition-shadow duration-300 group-aria-[current=page]:ring-2 group-aria-[current=page]:ring-gold"
      >
        <Image src={logo} alt="" width="80" height="80" class="h-10 w-10 object-contain" loading="eager" />
      </span>
      Home
    </a>
    <a
      href={site.phoneHref}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
      Call
    </a>
    <a
      href="/quote"
      aria-current={path === '/quote' ? 'page' : undefined}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-bold tracking-wide text-espresso"
    >
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-gold shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
      </span>
      Quote
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav')!;
  let lastY = scrollY;
  let ticking = false;

  addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = scrollY;
        nav.classList.toggle('is-condensed', y > 24);
        // Collapse out of the way going down; return the moment the user scrolls up.
        const goingDown = y > lastY && y > 140;
        nav.style.transform = goingDown ? 'translateY(-130%)' : '';
        lastY = y;
        ticking = false;
      });
    },
    { passive: true }
  );
</script>
