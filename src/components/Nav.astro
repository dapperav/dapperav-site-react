---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { site } from '../data/site';

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Our Work' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50 px-3 pt-3 sm:px-6">
  <div
    class="glass mx-auto flex max-w-6xl items-center justify-between rounded-full px-5 py-3 transition-all duration-300 [#site-nav.is-condensed_&]:py-2 [#site-nav.is-condensed_&]:shadow-xl sm:px-7"
  >
    <a href="/" class="flex items-center gap-3" aria-label="Dapper AV Solutions — home">
      <Image src={logo} alt="" width="96" height="96" class="h-12 w-12 object-contain" loading="eager" />
      <span class="font-display text-lg leading-tight font-semibold tracking-wide whitespace-nowrap">
        Dapper AV
        <span class="block text-[0.65rem] font-normal tracking-[0.28em] text-cocoa uppercase">Solutions</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 md:flex lg:gap-8" aria-label="Main">
      {
        links.map((l) => (
          <a
            href={l.href}
            aria-current={path === l.href ? 'page' : undefined}
            class="link-draw text-sm font-medium tracking-wide whitespace-nowrap text-espresso"
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={site.phoneHref}
        class="link-draw hidden text-sm font-medium tracking-wide whitespace-nowrap text-cocoa lg:inline-block"
      >
        {site.phone}
      </a>
      <a
        href="/quote"
        class="btn-sheen rounded-full bg-gold px-6 py-2.5 text-sm font-semibold tracking-wide whitespace-nowrap text-espresso shadow-sm transition-colors duration-300 hover:bg-gold-deep"
      >
        Request a Quote
      </a>
    </nav>

    <button
      id="nav-toggle"
      class="flex h-11 w-11 items-center justify-center md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <span class="relative block h-4 w-6">
        <span
          class="absolute top-0 left-0 h-0.5 w-6 bg-espresso transition-all duration-300 [#nav-toggle[aria-expanded='true']_&]:top-1/2 [#nav-toggle[aria-expanded='true']_&]:-translate-y-1/2 [#nav-toggle[aria-expanded='true']_&]:rotate-45"
        ></span>
        <span
          class="absolute top-1/2 left-0 h-0.5 w-6 -translate-y-1/2 bg-espresso transition-all duration-300 [#nav-toggle[aria-expanded='true']_&]:opacity-0"
        ></span>
        <span
          class="absolute bottom-0 left-0 h-0.5 w-6 bg-espresso transition-all duration-300 [#nav-toggle[aria-expanded='true']_&]:top-1/2 [#nav-toggle[aria-expanded='true']_&]:-translate-y-1/2 [#nav-toggle[aria-expanded='true']_&]:-rotate-45"
        ></span>
      </span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="glass mx-auto mt-2 hidden max-w-6xl rounded-3xl px-6 pt-2 pb-6 md:hidden"
  >
    <nav class="flex flex-col" aria-label="Mobile">
      {
        links.map((l) => (
          <a
            href={l.href}
            aria-current={path === l.href ? 'page' : undefined}
            class="border-b border-tan/30 py-4 font-display text-2xl aria-[current=page]:text-gold-deep"
          >
            {l.label}
          </a>
        ))
      }
      <a href={site.phoneHref} class="border-b border-tan/30 py-4 text-lg text-cocoa">Call {site.phone}</a>
      <a
        href="/quote"
        class="mt-5 rounded-full bg-gold px-5 py-3.5 text-center text-base font-semibold text-espresso"
      >
        Request a Quote
      </a>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav')!;
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('mobile-menu')!;

  let ticking = false;
  addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        nav.classList.toggle('is-condensed', scrollY > 24);
        ticking = false;
      });
    },
    { passive: true }
  );

  toggle.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    menu.classList.toggle('hidden', open);
  });
</script>
