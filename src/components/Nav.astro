---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { site } from '../data/site';

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'For Residential' },
  { href: '/business', label: 'For Business' },
  { href: '/work', label: 'Our Work' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!-- ── Desktop orbital nav: a centered spinning logo badge that expands
     into the full pill on hover, focus, or at the top of the page, and
     folds back to the badge as you scroll. ── -->
<header id="site-nav" class="at-top pointer-events-none fixed inset-x-0 top-3 z-50 hidden justify-center md:flex">
  <nav
    class="nav-shell glass pointer-events-auto flex items-center rounded-full p-1.5"
    aria-label="Main"
  >
    <div class="nav-group">
      <div class="nav-inner">
        <div class="flex items-center gap-7 pr-4 pl-6">
          {
            links.slice(0, 2).map((l) => (
              <a
                href={l.href}
                aria-current={path === l.href ? 'page' : undefined}
                class="link-draw text-sm font-medium tracking-wide whitespace-nowrap text-espresso"
              >
                {l.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <a href="/" class="shrink-0" aria-label="Dapper AV Solutions — home">
      <Image
        src={logo}
        alt=""
        width="112"
        height="112"
        class="logo-spin h-12 w-12 object-contain"
        loading="eager"
      />
    </a>

    <div class="nav-group">
      <div class="nav-inner">
        <div class="flex items-center gap-7 pr-2 pl-4">
          {
            links.slice(2).map((l) => (
              <a
                href={l.href}
                aria-current={path === l.href ? 'page' : undefined}
                class="link-draw text-sm font-medium tracking-wide whitespace-nowrap text-espresso"
              >
                {l.label}
              </a>
            ))
          }
          <a
            href="/quote"
            class="btn-sheen rounded-full bg-gold px-6 py-2.5 text-sm font-semibold tracking-wide whitespace-nowrap text-espresso shadow-sm transition-colors duration-300 hover:bg-gold-deep"
          >
            Request a Quote
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Width animates via the 0fr → 1fr grid trick; opacity rides along. */
  .nav-group {
    display: grid;
    grid-template-columns: 0fr;
    opacity: 0;
    transition:
      grid-template-columns 0.55s var(--ease-tailored),
      opacity 0.3s ease 0.05s;
  }

  .nav-inner {
    overflow: hidden;
    min-width: 0;
  }

  #site-nav.at-top .nav-group,
  .nav-shell:hover .nav-group,
  .nav-shell:focus-within .nav-group {
    grid-template-columns: 1fr;
    opacity: 1;
  }

  /* The roundel spins like a record on the platter. */
  @keyframes logo-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .logo-spin {
    animation: logo-spin 12s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-spin {
      animation: none;
    }
    .nav-group {
      transition: none;
    }
  }
</style>

<!-- ── Mobile bottom dock — the only nav on phones. Center logo = Home. ── -->
<nav
  class="glass fixed inset-x-3 bottom-3 z-50 rounded-3xl pb-[env(safe-area-inset-bottom)] md:hidden"
  aria-label="Mobile"
>
  <div class="grid grid-cols-5 items-end">
    <a
      href="/services"
      aria-current={path === '/services' ? 'page' : undefined}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa aria-[current=page]:text-gold-deep"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
        <rect x="2" y="4" width="20" height="13" rx="2.5" />
        <path d="M8 21h8m-4-4v4" />
      </svg>
      Residential
    </a>
    <a
      href="/work"
      aria-current={path === '/work' ? 'page' : undefined}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa aria-[current=page]:text-gold-deep"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="3" />
        <circle cx="9" cy="9" r="2" />
        <path d="m21 15-3.5-3.5a2 2 0 0 0-2.83 0L6 20" />
      </svg>
      Our Work
    </a>
    <a
      href="/"
      aria-current={path === '/' ? 'page' : undefined}
      aria-label="Dapper AV Solutions — home"
      class="group relative flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa aria-[current=page]:text-gold-deep"
    >
      <span
        class="glass -mt-8 flex h-14 w-14 items-center justify-center rounded-full shadow-lg transition-shadow duration-300 group-aria-[current=page]:ring-2 group-aria-[current=page]:ring-gold"
      >
        <Image src={logo} alt="" width="80" height="80" class="h-10 w-10 object-contain" loading="eager" />
      </span>
      Home
    </a>
    <a
      href={site.phoneHref}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-semibold tracking-wide text-cocoa"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
      Call
    </a>
    <a
      href="/quote"
      aria-current={path === '/quote' ? 'page' : undefined}
      class="flex flex-col items-center gap-1 py-2.5 text-[0.65rem] font-bold tracking-wide text-espresso"
    >
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-gold shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
      </span>
      Quote
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav')!;
  let ticking = false;

  const update = () => {
    nav.classList.toggle('at-top', scrollY < 80);
    ticking = false;
  };
  update();

  addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    },
    { passive: true }
  );
</script>
