---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import BrandStrip from '../components/BrandStrip.astro';
import heroImage from '../assets/header-bg.jpg';
import markPortrait from '../assets/mark-portrait.jpg';
import { site, commitments, services, process } from '../data/site';

const residential = services.filter((s) => s.category === 'residential');
import { gallery } from '../data/gallery';

const featured = gallery.slice(0, 3);
---

<Layout
  title="Dapper AV Solutions — TV Mounting, Home Theater & Smart Home in Richmond, Katy & Sugar Land, TX"
  description="Professional, precise, and personal AV installation across Fort Bend County — Richmond, Rosenberg, Fulshear, Sugar Land, Stafford & Katy: TV mounting, home theater, whole-home audio, smart home, and commercial AV. Free on-site consultations."
>
  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="relative flex min-h-[92svh] items-center overflow-hidden bg-roast">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt=""
        class="kenburns h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
        widths={[640, 1024, 1536, 2048]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-roast/95 via-roast/70 to-roast/30"></div>
      <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-roast/80 to-transparent"></div>
    </div>

    <div class="relative mx-auto w-full max-w-6xl px-5 pt-28 pb-20 sm:px-8">
      <p class="text-xs font-semibold tracking-[0.3em] text-gold uppercase" data-reveal>
        Fort Bend County's AV specialists
      </p>
      <h1
        class="font-display mt-6 max-w-3xl text-4xl leading-[1.08] font-semibold text-balance text-cream sm:text-6xl lg:text-7xl"
        data-reveal
        style="--rd: 120ms"
      >
        Experience the <span class="text-gold">Dapper AV</span> difference
      </h1>
      <p class="mt-7 max-w-xl text-lg leading-relaxed text-cream/80" data-reveal style="--rd: 240ms">
        {site.tagline}
      </p>
      <div class="mt-10 flex flex-wrap gap-4" data-reveal style="--rd: 360ms">
        <a
          href="/quote"
          class="btn-sheen rounded-full bg-gold px-8 py-4 text-base font-semibold text-espresso transition-colors duration-300 hover:bg-gold-deep"
        >
          Get a Free Quote
        </a>
        <a
          href="/services"
          class="glass-dark rounded-full px-8 py-4 text-base font-medium text-cream transition-colors duration-300 hover:text-gold"
        >
          View Our Services
        </a>
      </div>
    </div>

    <!-- Scroll cue -->
    <div
      class="absolute bottom-7 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 sm:flex"
      data-reveal
      style="--rd: 900ms"
      aria-hidden="true"
    >
      <span class="text-[0.6rem] font-semibold tracking-[0.3em] text-cream/60 uppercase">Scroll</span>
      <span class="scroll-cue-line block h-10 w-px bg-gold"></span>
    </div>
  </section>

  <BrandStrip />

  <!-- ── The Dapper Standard ──────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-5 py-24 sm:px-8 sm:py-32">
    <SectionHeading
      eyebrow="The Dapper Standard"
      title="Precision meets artistry in every installation"
      lead="We don't just install technology — we craft experiences that enhance the way you live. Every detail handled with the care of a well-tailored suit."
    />
    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        commitments.map((c, i) => (
          <div class="glass rounded-3xl p-8" data-reveal style={`--rd: ${i * 90}ms`}>
            <span class="font-display text-3xl text-gold-deep" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-display mt-4 text-xl font-semibold">{c.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-cocoa">{c.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ── Services ─────────────────────────────────────────────────── -->
  <section class="bg-parchment">
    <div class="mx-auto max-w-6xl px-5 py-24 sm:px-8 sm:py-32">
      <SectionHeading
        eyebrow="What we do"
        title="From a single TV to a whole building"
        lead="One standard of workmanship, whether it's a single TV or a whole building. Honest starting prices up front — the full breakdown is a click away."
      />
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          residential.map((s, i) => (
            <a
              href={`/services#${s.id}`}
              class="glass group flex flex-col rounded-3xl p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
              data-reveal
              style={`--rd: ${(i % 3) * 90}ms`}
            >
              <h3 class="font-display text-xl font-semibold">{s.title}</h3>
              <p class="mt-3 grow text-sm leading-relaxed text-cocoa">{s.blurb}</p>
              <div class="mt-6 flex items-center justify-between border-t border-tan/50 pt-5">
                <span class="text-sm font-semibold text-gold-deep">{s.price}</span>
                <span class="text-sm font-medium text-espresso transition-transform duration-300 group-hover:translate-x-1">
                  Details →
                </span>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Business strip -->
      <a
        href="/business"
        class="pinstripe group mt-6 block rounded-3xl bg-espresso p-8 shadow-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl sm:p-10"
        data-reveal
      >
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="flex items-center gap-3 text-xs font-semibold tracking-[0.28em] text-gold uppercase">
              <span class="block h-2 w-2 rounded-full bg-gold" aria-hidden="true"></span>
              For your business
            </p>
            <h3 class="font-display mt-3 text-2xl font-semibold text-cream sm:text-3xl">
              Commercial AV, UniFi networks, cameras & managed IT
            </h3>
            <p class="mt-3 max-w-xl text-sm leading-relaxed text-cream/70">
              An IT department for businesses that don't have one — installed, then managed. Custom-quoted
              after a free site survey.
            </p>
          </div>
          <span class="btn-sheen shrink-0 rounded-full bg-gold px-7 py-3.5 text-center text-sm font-semibold text-espresso transition-colors duration-300 group-hover:bg-gold-deep">
            Business services →
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- ── Featured work ────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-5 py-24 sm:px-8 sm:py-32">
    <SectionHeading
      eyebrow="Our work"
      title="Rooms we've dressed up"
      lead="A look at the kind of spaces we build — clean lines, hidden wires, and technology that disappears into the design."
    />
    <div class="mt-16 grid gap-6 sm:grid-cols-3">
      {
        featured.map((item, i) => (
          <a
            href="/work"
            class="card-zoom glass group block overflow-hidden rounded-3xl transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
            data-reveal
            style={`--rd: ${i * 100}ms`}
          >
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={item.image}
                alt={item.alt}
                class="h-full w-full object-cover"
                widths={[480, 768, 1024]}
                sizes="(min-width: 640px) 33vw, 100vw"
              />
            </div>
            <div class="p-5">
              <h3 class="font-display font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm text-cocoa">{item.caption}</p>
            </div>
          </a>
        ))
      }
    </div>
    <div class="mt-12 text-center" data-reveal>
      <a href="/work" class="link-draw font-medium text-gold-deep">See the full gallery →</a>
    </div>
  </section>

  <!-- ── Process ──────────────────────────────────────────────────── -->
  <section class="pinstripe bg-espresso">
    <div class="mx-auto max-w-6xl px-5 py-24 sm:px-8 sm:py-32">
      <SectionHeading
        eyebrow="How we work"
        title="Four steps, zero surprises"
        tone="dark"
      />
      <ol class="mt-16 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        {
          process.map((p, i) => (
            <li data-reveal style={`--rd: ${i * 110}ms`}>
              <span class="font-display text-4xl font-semibold text-gold" aria-hidden="true">
                {p.step}
              </span>
              <h3 class="font-display mt-4 text-lg font-semibold text-cream">{p.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-cream/65">{p.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ── Meet the owner ───────────────────────────────────────────── -->
  <section class="grooves mx-auto grid max-w-6xl items-center gap-12 px-5 py-24 sm:px-8 sm:py-32 lg:grid-cols-[2fr_3fr] lg:gap-20">
    <div class="relative mx-auto w-full max-w-md" data-reveal>
      <!-- offset gold frame — the tailored detail -->
      <div class="absolute -inset-0 translate-x-3 translate-y-3 rounded-[2rem] border-2 border-gold" aria-hidden="true"></div>
      <Image
        src={markPortrait}
        alt="Mark Immler, owner of Dapper AV Solutions, in a blue plaid blazer"
        class="relative aspect-[4/5] w-full rounded-[2rem] object-cover"
        widths={[480, 768, 1024, 1440]}
        sizes="(min-width: 1024px) 40vw, (min-width: 640px) 28rem, 100vw"
      />
    </div>

    <div>
      <p class="flex items-center gap-3 text-xs font-semibold tracking-[0.28em] text-gold-deep uppercase" data-reveal>
        <span class="block h-2 w-2 rounded-full bg-gold" aria-hidden="true"></span>
        Meet the owner
      </p>
      <h2
        class="font-display mt-4 text-3xl leading-tight font-semibold text-balance sm:text-4xl"
        data-reveal
        style="--rd: 80ms"
      >
        The Dapper Difference has a face
      </h2>
      <blockquote
        class="font-display mt-7 border-l-2 border-gold pl-5 text-xl leading-snug font-medium italic sm:text-2xl"
        data-reveal
        style="--rd: 160ms"
      >
        "Excellence isn't an accident — it's our standard."
      </blockquote>
      <p class="mt-7 leading-relaxed text-cocoa" data-reveal style="--rd: 240ms">
        I'm Mark Immler, and Dapper AV is mine — which means it's my name on every quote, my hands on
        every install, and my cell number at the top of this page. Every project begins with
        understanding your vision. From the initial consultation to the final calibration, I handle
        every detail with precision and care — because your space deserves nothing less than tailored.
      </p>
      <p class="font-display mt-8 text-lg font-semibold" data-reveal style="--rd: 320ms">
        Mark Immler
        <span class="mt-0.5 block text-xs font-normal tracking-[0.22em] text-cocoa uppercase">
          Owner · Dapper AV Solutions
        </span>
      </p>
    </div>
  </section>

  <ReviewsSection />

  <CtaBand />
</Layout>
