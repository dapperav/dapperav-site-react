---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import { gallery } from '../data/gallery';

const filters = [
  { id: 'all', label: 'All projects' },
  { id: 'residential', label: 'Residential' },
  { id: 'commercial', label: 'Commercial' },
];
---

<Layout
  title="Our Work — Dapper AV Solutions"
  description="A gallery of Dapper AV installations across Greater Houston: media walls, home theaters, sports bar video walls, and conference room AV."
>
  <section class="mx-auto max-w-6xl px-5 pt-36 pb-14 sm:px-8 sm:pt-44">
    <SectionHeading
      eyebrow="Our work"
      title="Spaces, tailored"
      lead="Clean lines, hidden wires, technology that disappears into the design. Here's the kind of work we do for Houston homes and businesses."
      align="left"
    />
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-24 sm:px-8 sm:pb-32">
    <!-- Filters -->
    <div class="flex flex-wrap gap-2" role="group" aria-label="Filter projects" data-reveal>
      {
        filters.map((f) => (
          <button
            type="button"
            data-filter={f.id}
            aria-pressed={f.id === 'all' ? 'true' : 'false'}
            class="rounded-sm border border-tan px-5 py-2.5 text-sm font-medium transition-colors duration-300 hover:border-gold-deep hover:text-gold-deep aria-pressed:border-espresso aria-pressed:bg-espresso aria-pressed:text-cream"
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <!-- Grid -->
    <div id="gallery-grid" class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        gallery.map((item, i) => (
          <figure
            class="card-zoom gallery-item overflow-hidden rounded-sm border border-tan/60 bg-parchment/50"
            data-category={item.category}
            data-reveal
            style={`--rd: ${(i % 3) * 90}ms`}
          >
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={item.image}
                alt={item.alt}
                class="h-full w-full object-cover"
                widths={[480, 768, 1024, 1536]}
                sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              />
            </div>
            <figcaption class="p-5">
              <p class="text-[0.65rem] font-semibold tracking-[0.24em] text-gold-deep uppercase">
                {item.category}
              </p>
              <h2 class="font-display mt-1.5 text-lg font-semibold">{item.title}</h2>
              <p class="mt-1 text-sm leading-relaxed text-cocoa">{item.caption}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="mt-14 rounded-sm border border-tan/60 bg-parchment/60 p-6 text-center text-sm leading-relaxed text-cocoa" data-reveal>
      Want to see work similar to your project? <a href="/quote" class="link-draw font-semibold text-gold-deep">Tell us what you have in mind</a>
      and we'll share relevant examples during your free consultation.
    </p>
  </section>

  <CtaBand title="Picture your space here" />

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const items = document.querySelectorAll<HTMLElement>('.gallery-item');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        const filter = btn.dataset.filter;
        items.forEach((item) => {
          item.classList.toggle('hidden', filter !== 'all' && item.dataset.category !== filter);
        });
      });
    });
  </script>
</Layout>
