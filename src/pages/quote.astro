---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import markAvatar from '../assets/mark-avatar.jpg';
import { site, serviceAreas, quoteFormOptions, WEB3FORMS_ACCESS_KEY } from '../data/site';

const selectCls =
  'mt-2 w-full rounded-xl border border-tan/70 bg-white/55 px-4 py-3 text-sm text-espresso placeholder:text-cocoa/50 focus:border-gold-deep focus:outline-none focus:ring-2 focus:ring-gold/40';
const inputCls = `${selectCls} invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-700`;
const labelCls = 'block text-xs font-semibold tracking-[0.14em] uppercase text-cocoa';
---

<Layout
  title="Request a Quote — Dapper AV Solutions"
  description="Get a free, itemized quote for TV mounting, home theater, whole-home audio, smart home, or commercial AV in Richmond, Katy, Sugar Land & Fort Bend County. We respond within one business day."
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-16 sm:px-8 md:pt-44">
    <SectionHeading
      eyebrow="Request a quote"
      title="Tell us about your project"
      lead="Fill this out and we'll get back to you within one business day with next steps — usually a quick call and a free on-site consultation. Prefer to talk now? Call or text us directly."
      align="left"
    />
  </section>

  <section class="mx-auto grid max-w-6xl gap-12 px-5 pb-24 sm:px-8 lg:grid-cols-[1.6fr_1fr]">
    <!-- ── Form ─────────────────────────────────────────────────────── -->
    <div data-reveal>
      <form id="quote-form" novalidate class="glass rounded-3xl p-7 sm:p-10">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="qf-name" class={labelCls}>Name *</label>
            <input id="qf-name" name="name" type="text" required autocomplete="name" placeholder="Your name" class={inputCls} />
          </div>
          <div>
            <label for="qf-email" class={labelCls}>Email *</label>
            <input id="qf-email" name="email" type="email" required autocomplete="email" placeholder="you@example.com" class={inputCls} />
          </div>
          <div>
            <label for="qf-phone" class={labelCls}>Phone *</label>
            <input id="qf-phone" name="phone" type="tel" required autocomplete="tel" placeholder="(555) 555-5555" class={inputCls} />
          </div>
          <div>
            <label for="qf-service" class={labelCls}>Service needed *</label>
            <select id="qf-service" name="service" required class={selectCls}>
              <option value="" selected disabled>Select a service…</option>
              {quoteFormOptions.services.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div>
            <label for="qf-timeline" class={labelCls}>Timeline</label>
            <select id="qf-timeline" name="timeline" class={selectCls}>
              <option value="" selected>When would you like this done?</option>
              {quoteFormOptions.timelines.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>
          <div>
            <label for="qf-budget" class={labelCls}>Budget</label>
            <select id="qf-budget" name="budget" class={selectCls}>
              <option value="" selected>Rough budget range (optional)</option>
              {quoteFormOptions.budgets.map((b) => <option value={b}>{b}</option>)}
            </select>
          </div>
        </div>

        <div class="mt-6">
          <label for="qf-message" class={labelCls}>Project details *</label>
          <textarea
            id="qf-message"
            name="message"
            rows="5"
            required
            placeholder="Tell us about the room, the equipment you have or want, and what you're trying to achieve…"
            class={inputCls}></textarea>
        </div>

        <!-- Honeypot: hidden from humans, catnip for bots -->
        <input
          type="checkbox"
          name="botcheck"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          class="absolute -left-[9999px] h-px w-px"
        />

        <p id="qf-hint" class="mt-4 hidden text-sm font-medium text-red-800" role="alert"></p>

        <button
          type="submit"
          id="qf-submit"
          class="btn-sheen mt-7 w-full rounded-full bg-gold px-8 py-4 text-base font-semibold text-espresso transition-colors duration-300 hover:bg-gold-deep disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
        >
          Send my quote request
        </button>
        <p class="mt-4 text-xs leading-relaxed text-cocoa">
          We only use your details to respond to this request. No newsletters, no spam.
        </p>
      </form>

      <!-- Success state -->
      <div id="qf-success" class="glass hidden rounded-3xl border-gold p-10 text-center" role="status">
        <p class="font-display text-3xl font-semibold">Request received.</p>
        <p class="mx-auto mt-4 max-w-md leading-relaxed text-cocoa">
          Thanks — your project details are on their way to us. We'll get back to you within one business day.
          Need us sooner? Call or text <a href={site.phoneHref} class="link-draw font-semibold text-gold-deep">{site.phone}</a>.
        </p>
      </div>

      <!-- Error state -->
      <div id="qf-error" class="mt-6 hidden rounded-3xl border border-red-800/40 bg-red-50/90 p-8 shadow-lg backdrop-blur-md" role="alert">
        <p class="font-semibold text-red-900">Something went wrong sending your request.</p>
        <p class="mt-2 text-sm leading-relaxed text-red-900/80">
          Please reach us directly instead — call or text
          <a href={site.phoneHref} class="font-semibold underline">{site.phone}</a>
          or email
          <a href={`mailto:${site.email}`} class="font-semibold underline">{site.email}</a>.
        </p>
      </div>
    </div>

    <!-- ── Sidebar ──────────────────────────────────────────────────── -->
    <aside class="space-y-8" data-reveal style="--rd: 120ms">
      <div class="pinstripe rounded-3xl bg-espresso p-8 text-cream shadow-xl">
        <div class="flex items-center gap-4">
          <Image
            src={markAvatar}
            alt="Mark Immler, owner of Dapper AV Solutions"
            class="h-16 w-16 rounded-full border-2 border-gold object-cover"
            widths={[128, 192]}
            sizes="4rem"
          />
          <div>
            <p class="font-display font-semibold">Mark Immler</p>
            <p class="text-xs tracking-[0.18em] text-cream/60 uppercase">Owner</p>
          </div>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-cream/75">
          You'll be talking with me — the owner, not a call center.
        </p>
        <h2 class="mt-6 text-xs font-semibold tracking-[0.22em] text-gold uppercase">Talk to me directly</h2>
        <ul class="mt-5 space-y-3 text-sm">
          <li><a href={site.phoneHref} class="link-draw text-base font-semibold">Call {site.phone}</a></li>
          <li><a href={site.smsHref} class="link-draw">Text me — I reply fast</a></li>
          <li><a href={`mailto:${site.email}`} class="link-draw">{site.email}</a></li>
          <li class="pt-2 text-cream/65">{site.hours}</li>
        </ul>
      </div>

      <div class="glass rounded-3xl p-8">
        <h2 class="text-xs font-semibold tracking-[0.22em] text-gold-deep uppercase">What to expect</h2>
        <ul class="mt-5 space-y-4 text-sm leading-relaxed text-cocoa">
          <li class="flex gap-3">
            <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-gold" aria-hidden="true"></span>
            A response within one business day
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-gold" aria-hidden="true"></span>
            A free on-site consultation at your convenience
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-gold" aria-hidden="true"></span>
            An itemized quote — the number you see is the number you pay
          </li>
        </ul>
      </div>

      <div class="glass rounded-3xl p-8">
        <h2 class="text-xs font-semibold tracking-[0.22em] text-gold-deep uppercase">Where we work</h2>
        <dl class="mt-5 space-y-4 text-sm">
          {
            serviceAreas.map((a) => (
              <div>
                <dt class="font-semibold">{a.county}</dt>
                <dd class="mt-1 leading-relaxed text-cocoa">{a.cities.join(' · ')}</dd>
              </div>
            ))
          }
        </dl>
        <p class="mt-5 text-xs leading-relaxed text-cocoa">
          Don't see your area? Ask — we can often make it work.
        </p>
      </div>
    </aside>
  </section>
</Layout>

<script is:inline define:vars={{ accessKey: WEB3FORMS_ACCESS_KEY }}>
  const form = document.getElementById('quote-form');
  const successBox = document.getElementById('qf-success');
  const errorBox = document.getElementById('qf-error');
  const hint = document.getElementById('qf-hint');
  const submitBtn = document.getElementById('qf-submit');

  // Pre-select service from ?service= links on the services page
  const preselect = new URLSearchParams(location.search).get('service');
  if (preselect) {
    const select = form.elements.service;
    const match = [...select.options].find((o) => preselect.toLowerCase().includes(o.value.toLowerCase().split(' ')[0].toLowerCase()) || o.value === preselect);
    select.value = match ? match.value : 'Other';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hint.classList.add('hidden');
    errorBox.classList.add('hidden');

    if (!form.checkValidity()) {
      hint.textContent = 'Please fill in the required fields (name, email, phone, service, and project details).';
      hint.classList.remove('hidden');
      form.querySelector(':invalid')?.focus();
      return;
    }

    if (accessKey.startsWith('REPLACE_WITH')) {
      // Form service not configured yet — fail loudly toward a human channel.
      errorBox.classList.remove('hidden');
      errorBox.scrollIntoView({ block: 'center', behavior: 'smooth' });
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          access_key: accessKey,
          subject: `Quote request from ${data.name} — ${data.service}`,
          from_name: 'dapperav.com quote form',
          ...data,
        }),
      });
      const json = await res.json();
      if (!res.ok || !json.success) throw new Error(json.message || `HTTP ${res.status}`);
      form.classList.add('hidden');
      successBox.classList.remove('hidden');
      successBox.scrollIntoView({ block: 'center', behavior: 'smooth' });
    } catch (err) {
      console.error('Quote form submission failed:', err);
      errorBox.classList.remove('hidden');
      errorBox.scrollIntoView({ block: 'center', behavior: 'smooth' });
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send my quote request';
    }
  });
</script>
